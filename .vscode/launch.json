{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "inputs": [
        {
            "id": "GetQuantowerPID",
            "type": "command",
            "command": "shellCommand.execute",
            "args": {
                "command": "powershell (Get-Process Starter).Id", 
                "description": "Finds the PID of the running Quantower UI process",
                "useSingleResult": true,
            }
        }
    ],
    "configurations": [
        {
            "name": "Attach to Quantower (Auto)",
            "type": "coreclr",
            "request": "attach",
            "processId": "${input:GetQuantowerPID}"
        }
    ]
}