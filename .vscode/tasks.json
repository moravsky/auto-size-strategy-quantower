{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build-debug",
			"command": "dotnet",
			"type": "process",
			"args": [
				"build",
				"-c",
				"Debug"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$msCompile"
		},
		{
			"label": "build-release",
			"command": "dotnet",
			"type": "process",
			"args": [
				"build",
				"-c",
				"Release"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$msCompile"
		}
	]
}